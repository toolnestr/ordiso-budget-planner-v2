rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles ───
    // Signed-in users can read all user profiles (needed for admin user list).
    // Users can create/update their own profile. Admins can update any profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null
        && isAdmin() && request.auth.uid != userId;
    }

    // ─── Per-user data collections ───
    // Every document carries a `userId` field. Users can only read/write their
    // own data. Demo users can read but NOT write (read-only demo).
    // Note: when reading a collection, Firestore evaluates the rule against
    // each document — documents where userId != requester are filtered out.
    match /{collection}/{docId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ─── Helper functions ───
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
