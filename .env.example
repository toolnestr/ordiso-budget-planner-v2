# ─── Environment variables ───────────────────────────────────────────────
# Copy this file to `.env` (locally) or set these in your Cloudflare Pages
# dashboard under Settings → Environment variables.

# NextAuth.js — generate a random secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret-string

# The public URL of your deployment. For local dev use http://localhost:3000.
# For Cloudflare Pages use your production URL, e.g. https://ordiso.pages.dev
NEXTAUTH_URL=http://localhost:3000
